generator client {
  provider = "prisma-client"
  output   = "./generated/prisma/client"
}


datasource db {
  provider = "postgresql"
}


model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("operator") // admin | operator
  projects  VideoProject[]
  createdAt DateTime @default(now())
}


model VideoProject {
  id        String   @id @default(cuid())
  title     String
  videoType String   // kobo | fangtan | xianchang | qingjing


  productName    String?
  constitutions  String[]
  solarTerm      String?
  targetAudience String?
  purpose        String   @default("培训")
  customNotes    String?


  status      String   @default("draft")
  // draft → script_done → images_done → video_done → published


  scriptModel String?
  imageModel  String?
  videoModel  String?


  scenes    VideoScene[]
  outputs   VideoOutput[]
  createdBy String
  creator   User     @relation(fields: [createdBy], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model VideoScene {
  id        String   @id @default(cuid())
  projectId String
  project   VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)


  sceneNo     Int
  duration    Int
  shotType    String
  visualDesc  String
  imagePrompt String   @db.Text
  voiceover   String   @db.Text
  subtitle    String
  musicMood   String?
  avatarRole  String?


  imageUrl    String?
  imageStatus String   @default("pending")
  imageError  String?


  videoClipUrl String?
  videoStatus  String  @default("pending")
  videoError   String?


  createdAt DateTime @default(now())
